# ===== LLM（OpenAI 兼容网关，必填）=====
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-chat

# ===== 助手品牌 / 知识边界（换文档站只改这几行）=====
ASSISTANT_NAME=云文档智能问答助手
KNOWLEDGE_SCOPE=人脸识别产品文档
# 拒答时给用户的示例提问，逗号分隔
EXAMPLE_QUESTIONS=人脸识别是什么？,人脸识别的计费方式是怎样的？

# ===== 爬虫入口 =====
# 抓取范围按该 URL 的路径前缀限定（如只爬 /document/product 下的页面）
TARGET_URL=https://cloud.tencent.com/document/product/867

# ===== 检索 / 输入 =====
MAX_INPUT_LENGTH=500
MAX_CONTEXT_LENGTH=4000
RAG_MAX_DISTANCE=0.55

# ===== 限流 / 配额（对外服务时按需调整）=====
RATE_LIMIT_PER_MINUTE=12
MAX_CONCURRENT_QA=20
MAX_CONCURRENT_QA_PER_IP=3
MAX_SESSIONS_PER_IP=30
MAX_NEW_SESSIONS_PER_MINUTE=10
# 每日 LLM token 预算，0=不限；对外开放强烈建议设上限防"账单攻击"
DAILY_TOKEN_BUDGET=0
